{
  "permissions": {
    "allow": [
      "Bash(cmake:*)",
      "Bash(./build/dtvm:*)",
      "Bash(build/dtvm:*)",
      "Bash(./build/evmStateTests:*)",
      "Bash(tools/format.sh:*)",
      "Bash(python3:*)",
      "Bash(git:*)",
      "Bash(g++:*)",
      "Bash(clang-format:*)",
      "Bash(solc:*)",
      "Bash(gdb:*)",
      "Bash(perf record:*)",
      "Bash(perf report:*)",
      "Bash(nm:*)",
      "Bash(xxd:*)",
      "Bash(jq:*)",
      "Bash(rg:*)",
      "Bash(tree:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(tac:*)",
      "Bash(echo:*)",
      "Bash(awk:*)",
      "Bash(grep:*)",
      "Bash(tee:*)",
      "Bash(xargs:*)",
      "Bash(env:*)",
      "Bash(timeout:*)",
      "Bash(dmesg:*)",
      "Bash(openspec:*)",
      "Bash(claude:*)",
      "Bash(npm list:*)",
      "WebSearch",
      "WebFetch(domain:claudefa.st)",
      "mcp__ide__getDiagnostics",
      "Skill(Notion:notion-create-page)",
      "Skill(Notion:notion-search)"
    ],
    "deny": [],
    "ask": []
  },
  "outputStyle": "default",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; case \"$FILE\" in *.cpp|*.h|*.cc|*.cxx) clang-format -style=file -i \"$FILE\";; esac"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/stop_validation.py"
          }
        ]
      }
    ]
  }
}
