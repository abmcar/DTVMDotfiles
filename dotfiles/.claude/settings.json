{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "d=\"$PWD\"; while [ \"$d\" != \"/\" ] && [ ! -f \"$d/.claude/hooks/check-dotfiles-sync.sh\" ]; do d=\"$(dirname \"$d\")\"; done; bash \"$d/.claude/hooks/check-dotfiles-sync.sh\"",
            "timeout": 5,
            "statusMessage": "Checking dotfiles sync..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-check.sh",
            "timeout": 15,
            "statusMessage": "Running housekeeping check..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "d=\"$PWD\"; while [ \"$d\" != \"/\" ] && [ ! -f \"$d/.claude/hooks/stop_validation.py\" ]; do d=\"$(dirname \"$d\")\"; done; python3 \"$d/.claude/hooks/stop_validation.py\"",
            "timeout": 120,
            "statusMessage": "Running format check..."
          }
        ]
      }
    ]
  }
}
